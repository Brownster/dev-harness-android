# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# HARNESS_SHARED_SECRET: Used for signing requests with HMAC SHA256.
HARNESS_SHARED_SECRET="MY_SHARED_SECRET"

# BACKEND_API_URL: The URL for the FastAPI backend.
BACKEND_API_URL="http://localhost:8000"
